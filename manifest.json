{
  "manifest_version": 3,
  "name": "Touch Chrome — 中键关闭标签",
  "version": "1.0.0",
  "description": "在网页上按下鼠标中键时关闭当前标签页。",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
